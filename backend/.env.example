# ==============================================================================
# EdgeTwin Copilot — Environment Configuration
# ==============================================================================

# LLM Provider Configuration
# Supported options:
#   - 'cached' (Offline mode, zero cloud costs / fallback)
#   - 'groq'   (High performance LLaMA-3 Cloud Inference, requires GROQ_API_KEY)
#   - 'ollama' (Local edge LLM execution, e.g., llama3)
LLM_PROVIDER=cached
GROQ_API_KEY=

# Data Source Mode (Plug-and-Play Integration)
# Supported options:
#   - 'simulator' (Standard demo mode generating telemetry patterns)
#   - 'mqtt'      (Real-world telemetry broker connection)
DATA_SOURCE=simulator

# MQTT Broker Configuration (Active only when DATA_SOURCE=mqtt)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=edgetwin/telemetry

# Out-of-band Notifications (Slack/Discord Webhook URL)
SLACK_WEBHOOK_URL=
